
manifest.json

{
  "manifest_version": 3,
  "name": "XULADP",
  "version": "5.5",
  "description": "Descarga grabaciones de Webex con el nombre del titulo.",
  "icons": { "48": "icon.png" },
  "content_scripts": [
    {
      "matches": ["*://adpmeet.webex.com/webapping/sites/adpmeet/recording/*"],
      "js": ["content.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}


content.js

(function () {
  if (window._xuladp) return;
  window._xuladp = true;

  var origFetch = window.fetch;
  var origOpen = XMLHttpRequest.prototype.open;
  var videoUrl = null;
  var working = false;
  var done = false;

  var btn = document.createElement('div');
  btn.id = '_xuladp_btn';
  btn.style.cssText =
    'position:fixed;top:14px;right:14px;width:38px;height:38px;' +
    'border-radius:50%;background:#2a2a3a;color:#666;display:flex;' +
    'align-items:center;justify-content:center;cursor:default;' +
    'z-index:2147483647;box-shadow:0 2px 8px rgba(0,0,0,.4);' +
    'opacity:.55;transition:all .2s;';
  btn.innerHTML =
    '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" ' +
    'stroke="currentColor" stroke-width="2.5" stroke-linecap="round" ' +
    'stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="15"/>' +
    '<polyline points="6 10 12 16 18 10"/></svg>';
  document.documentElement.appendChild(btn);

  function estado(e) {
    if (e === 'espera') {
      btn.style.background = '#2a2a3a'; btn.style.color = '#666';
      btn.style.cursor = 'default'; btn.style.opacity = '.55';
      btn.title = 'XULADP - esperando video';
    } else if (e === 'listo') {
      btn.style.background = '#0f3460'; btn.style.color = '#00e5ff';
      btn.style.cursor = 'pointer'; btn.style.opacity = '1';
      btn.title = 'XULADP - clic para descargar';
    } else if (e === 'bajando') {
      btn.style.color = '#ffc107'; btn.style.cursor = 'wait';
      btn.title = 'XULADP - descargando';
    } else if (e === 'ok') {
      btn.style.background = '#003320'; btn.style.color = '#00c853';
      btn.style.cursor = 'default';
      btn.title = 'XULADP - completado';
    } else if (e === 'error') {
      btn.style.background = '#3a0f0f'; btn.style.color = '#f44';
      btn.style.cursor = 'pointer';
      btn.title = 'XULADP - error, clic para reintentar';
    }
  }
  estado('espera');

  function nombre() {
    var h1 = document.querySelector('h1.recordingtitle') ||
             document.querySelector('h1.recordingTitle') ||
             document.querySelector('h1[class*="recording" i]');
    var t = h1 ? h1.innerText.trim() : 'webex_video';
    return t.replace(/[^a-z0-9 ._-]/gi, '_').substring(0, 80) || 'webex_video';
  }

  function descargar() {
    if (!videoUrl || working || done) return;
    working = true;
    estado('bajando');
    window.fetch = origFetch;
    XMLHttpRequest.prototype.open = origOpen;
    var file = nombre();
    origFetch(videoUrl, { credentials: 'include' })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.blob();
      })
      .then(function (blob) {
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = file + '.mp4';
        document.body.appendChild(a);
        a.click();
        a.remove();
        done = true;
        estado('ok');
      })
      .catch(function (err) {
        console.error('[XULADP]', err);
        working = false;
        estado('error');
      });
  }

  btn.addEventListener('click', descargar);

  function esBuena(u) {
    return typeof u === 'string' && u.indexOf('.mp4') !== -1 && u.indexOf('merge_') !== -1;
  }

  window.fetch = function () {
    var u = typeof arguments[0] === 'string' ? arguments[0] : (arguments[0] && arguments[0].url);
    if (!videoUrl && esBuena(u)) { videoUrl = u; estado('listo'); }
    return origFetch.apply(this, arguments);
  };

  XMLHttpRequest.prototype.open = function (m, u) {
    if (!videoUrl && esBuena(u)) { videoUrl = u; estado('listo'); }
    return origOpen.apply(this, arguments);
  };
})();

















